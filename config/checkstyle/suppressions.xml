<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Legacy naming conventions that cannot be safely changed -->
    <suppress checks="LocalVariableName" files="Main\.java" />
    <suppress checks="LocalVariableName" files="ViewListView\.java" />
    <suppress checks="MethodName" files="SwitchView\.java" />

    <!-- JavaStructureExtractor は単一のパーサクラスとして 800 行を超えるが、トークン列を順番に
         消化する状態機械なので機能単位で凝集しており分割する利点が薄いため許可。 -->
    <suppress checks="FileLength" files="JavaStructureExtractor\.java" />

    <!-- UmlMainFrame は Swing メニュー / ファイル選択 / レンダリング / プロジェクトロード /
         状態保持を 1 枚で抱える中心 GUI コントローラ。状態と Action リスナを安易に分割すると
         Swing イベントの追跡が困難になるため、ファイル長は許可する。 -->
    <suppress checks="FileLength" files="UmlMainFrame\.java" />

    <!-- PlantUmlSequenceDiagram の内部ヘルパは PlantUML テキスト・呼び出しスタック・visited
         セットなどを多数受け渡す必要があり、パラメータ数 8 を超える。外部 API は維持。
         注釈/コメント/フィルタ/再帰展開/制御構造ハンドラが集約された生成器であり、
         分割よりも 1 ファイルで読める方が保守性が高いためファイル長も許可。 -->
    <suppress checks="ParameterNumber" files="PlantUmlSequenceDiagram\.java" />
    <suppress checks="FileLength" files="PlantUmlSequenceDiagram\.java" />

    <!-- StyleSettingsDialog.buildForm は GridBag フォームの行を順に積むため、
         フィールドが増えるたびに行数が伸びる。1 関数に収めた方が UI の縦並びが直感的。 -->
    <suppress checks="MethodLength" files="StyleSettingsDialog\.java" />

    <!-- Main.java は CLI 引数パースと全 出力モード (UML / Gradle / Manifest / Deep Link /
         Component / Dependency / Summary / All / Sequence) のディスパッチャを兼ねるため、
         出力モードが増えるたびに main 内 dispatch とファイル全体が比例して伸びる。
         CLI の入口として凝集しており、機能単位での分割は反って関連性を失わせるため許可。 -->
    <suppress checks="FileLength" files="Main\.java" />
    <suppress checks="MethodLength" files="Main\.java" />
</suppressions>
