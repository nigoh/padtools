<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Legacy naming conventions that cannot be safely changed -->
    <suppress checks="LocalVariableName" files="Main\.java" />
    <suppress checks="LocalVariableName" files="ViewListView\.java" />
    <suppress checks="MethodName" files="SwitchView\.java" />

    <!-- JavaParser は単一の解析器クラスとして 800 行を超えるが、機能単位で凝集しているため許可 -->
    <suppress checks="FileLength" files="JavaParser\.java" />

    <!-- JavaSourceConverterTest は網羅的なテストケースを 1 クラスにまとめており 800 行を超える -->
    <suppress checks="FileLength" files="JavaSourceConverterTest\.java" />
</suppressions>
