<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/full_nav"
    android:label="Full Navigation"
    app:startDestination="@id/homeFragment">

    <!-- Global action -->
    <action
        android:id="@+id/action_global_home"
        app:destination="@id/homeFragment"
        app:popUpTo="@id/homeFragment"
        app:popUpToInclusive="true" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/action_home_to_confirm"
            app:destination="@id/confirmDialog" />
        <argument
            android:name="userId"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.DetailFragment"
        android:label="Detail">
        <argument
            android:name="itemId"
            app:argType="integer" />
        <argument
            android:name="itemName"
            app:argType="string"
            app:nullable="true" />
        <deepLink app:uri="https://www.example.com/detail/{itemId}" />
        <deepLink app:uri="example://detail/{itemId}" />
    </fragment>

    <dialog
        android:id="@+id/confirmDialog"
        android:name="com.example.ConfirmDialog"
        android:label="Confirm" />

    <activity
        android:id="@+id/settingsActivity"
        android:name="com.example.SettingsActivity"
        android:label="Settings" />

    <navigation
        android:id="@+id/authGraph"
        android:label="Auth Flow"
        app:startDestination="@id/loginFragment">
        <fragment
            android:id="@+id/loginFragment"
            android:name="com.example.auth.LoginFragment"
            android:label="Login" />
    </navigation>

    <include app:graph="@navigation/secondary_nav" />

</navigation>
